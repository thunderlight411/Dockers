FROM alpine:3.20

LABEL org.opencontainers.image.title="backup-runner"
LABEL org.opencontainers.image.description="Backup container for SFTP + MySQL dumps"
LABEL org.opencontainers.image.licenses="MIT"

# Install dependencies
RUN apk add --no-cache \
    bash \
    openssh-client \
    sshpass \
    mysql-client \
    unzip \
    zip \
    coreutils \
    findutils

CMD ["/bin/bash"]
